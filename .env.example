# ============================================================
# REUNUSA 2026 — Vercel Environment Variables
# ============================================================
# Set kedua variabel ini di:
#   Vercel Dashboard → Project → Settings → Environment Variables
#   (tambahkan untuk Environment: Production + Preview + Development)
# ============================================================

# URL project Supabase kamu (tanpa trailing slash)
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co

# Service Role Key (SECRET) — bukan anon/publishable key!
# Ada di: Supabase Dashboard → Project Settings → API → service_role
# Jika key lama dihapus/di-rotate, gunakan key yang baru dibuat.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── TIDAK DIPAKAI LAGI ───────────────────────────────────────
# VITE_SUPABASE_URL        → frontend tidak akses DB langsung
# VITE_SUPABASE_ANON_KEY   → frontend tidak akses DB langsung
# SUPABASE_SECRET_KEY      → alias lama, sudah diganti di atas
# ─────────────────────────────────────────────────────────────
