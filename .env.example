# Supabase (publishable / anon — safe to expose to the browser, BUT
# real protection comes from Row Level Security policies on your tables).
# Set the same values in your hosting provider (e.g. Vercel → Project Settings → Environment Variables).
VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here
