# Supabase server-side credentials for Vercel Serverless Functions.
# These are NOT used directly by the public HTML/browser code.
# Set these in Vercel → Project Settings → Environment Variables, then redeploy.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
# Optional fallback if you use Supabase's newer server-only secret key instead:
# SUPABASE_SECRET_KEY=your_supabase_secret_key_here

# Legacy note:
# VITE_SUPABASE_URL / VITE_SUPABASE_ANON_KEY are intentionally not required
# because frontend pages call same-origin /api/* endpoints instead of Supabase directly.
