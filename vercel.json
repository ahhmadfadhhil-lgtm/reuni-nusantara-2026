{
  "version": 2,
  "builds": [
    {
      "src": "api/**/*.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": ["api/**"]
      }
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/register",    "dest": "/public/register.html" },
    { "src": "/ticket",      "dest": "/public/ticket.html" },
    { "src": "/validate",    "dest": "/public/validate.html" },
    { "src": "/home",        "dest": "/public/index.html" },
    { "src": "/merchandise", "dest": "/public/merchandise.html" },
    { "src": "/(register|ticket|validate|merchandise|index)\.html", "dest": "/public/$1.html" },
    { "src": "/assets/(.*)", "dest": "/public/assets/$1" },
    { "src": "/index\.css",  "dest": "/public/index.css" },
    { "src": "/robots\.txt", "dest": "/public/robots.txt" },
    { "src": "/",            "dest": "/public/register.html" }
  ]
}
